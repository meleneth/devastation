services:
  dns:
    image: coredns/coredns:1.11.1
    command: ["-conf", "/etc/coredns/Corefile"]
    restart: unless-stopped
    volumes:
      - {{ devastation_paths.dns }}/Corefile:/etc/coredns/Corefile:ro
    ports:
      - "127.0.0.1:53:53/udp"
      - "127.0.0.1:53:53/tcp"
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.dns }}

  registry:
    image: registry:2.8.3
    restart: unless-stopped
    environment:
      REGISTRY_HTTP_ADDR: 0.0.0.0:443
      REGISTRY_HTTP_TLS_CERTIFICATE: /certs/tls.crt
      REGISTRY_HTTP_TLS_KEY: /certs/tls.key
      REGISTRY_HTTP_DEBUG_ADDR: 0.0.0.0:{{ registry_metrics_port }}
      REGISTRY_HTTP_DEBUG_PROMETHEUS_ENABLED: "true"
      REGISTRY_STORAGE_FILESYSTEM_ROOTDIRECTORY: /var/lib/registry
{% if registry_enable_auth %}
      REGISTRY_AUTH: htpasswd
      REGISTRY_AUTH_HTPASSWD_REALM: devastation
      REGISTRY_AUTH_HTPASSWD_PATH: /auth/htpasswd
{% endif %}
    volumes:
      - {{ devastation_paths.registry }}/data:/var/lib/registry
      - {{ devastation_paths.certs }}/registry.{{ devastation_domain }}:/certs:ro
{% if registry_enable_auth %}
      - {{ devastation_paths.registry }}/auth:/auth:ro
{% endif %}
    ports:
      - "443:443"
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.registry }}

{% if registry_pull_through_cache_enabled %}
  registry-cache:
    image: registry:2.8.3
    restart: unless-stopped
    environment:
      REGISTRY_PROXY_REMOTEURL: {{ registry_pull_through_remoteurl }}
      REGISTRY_HTTP_DEBUG_ADDR: 0.0.0.0:{{ registry_metrics_port }}
      REGISTRY_HTTP_DEBUG_PROMETHEUS_ENABLED: "true"
      REGISTRY_STORAGE_FILESYSTEM_ROOTDIRECTORY: /var/lib/registry
    volumes:
      - {{ devastation_paths.registry }}/pull-through-cache:/var/lib/registry
    ports:
      - "5001:5000"
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.registry_cache }}
{% endif %}

  apt-cache:
    image: sameersbn/apt-cacher-ng:3.7.4-20220421
    restart: unless-stopped
    volumes:
      - {{ devastation_paths.apt_cache }}/data:/var/cache/apt-cacher-ng
    ports:
      - "{{ apt_cache_port }}:3142"
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.apt_cache }}

  vault:
    image: hashicorp/vault:{{ vault_version }}
    restart: unless-stopped
    cap_add:
      - IPC_LOCK
    environment:
      VAULT_DEV_ROOT_TOKEN_ID: {{ vault_dev_root_token }}
      VAULT_DEV_LISTEN_ADDRESS: 0.0.0.0:{{ vault_port }}
      VAULT_ADDR: http://127.0.0.1:{{ vault_port }}
    command: ["server", "-dev", "-dev-listen-address=0.0.0.0:{{ vault_port }}"]
    ports:
      - "{{ vault_port }}:{{ vault_port }}"
    volumes:
      - {{ devastation_paths.vault }}/data:/vault/file
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.vault }}

  eventline:
    image: {{ goaws_image }}
    restart: unless-stopped
    ports:
      - "{{ goaws_port }}:4100"
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.eventline }}

  storage:
    image: {{ minio_image }}
    restart: unless-stopped
    command: ["server", "/data", "--console-address", ":{{ minio_console_port }}"]
    environment:
      MINIO_ROOT_USER: {{ minio_root_user }}
      MINIO_ROOT_PASSWORD: {{ minio_root_password }}
    ports:
      - "{{ minio_api_port }}:9000"
      - "{{ minio_console_port }}:{{ minio_console_port }}"
    volumes:
      - {{ devastation_paths.storage }}/data:/data
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.storage }}

  www:
    image: {{ www_image }}
    restart: unless-stopped
    volumes:
      - {{ devastation_paths.www }}/html:/usr/share/nginx/html:ro
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.www }}

{% for pg in postgres_databases %}
  {{ pg.service }}:
    image: postgres:{{ postgres_version }}
    restart: unless-stopped
    environment:
      POSTGRES_USER: {{ postgres_default_user }}
      POSTGRES_PASSWORD: {{ postgres_default_password }}
      POSTGRES_DB: {{ pg.database }}
    ports:
      - "{{ pg.host_port }}:5432"
    volumes:
      - {{ devastation_paths.postgres }}/{{ pg.service }}:/var/lib/postgresql
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets[pg.subnet_key] }}

  {{ pg.service }}-exporter:
    image: {{ postgres_exporter_image }}
    restart: unless-stopped
    environment:
      DATA_SOURCE_NAME: postgresql://{{ postgres_default_user }}:{{ postgres_default_password }}@{{ pg.service }}:5432/{{ pg.database }}?sslmode=disable
    depends_on:
      - {{ pg.service }}
    networks:
      - devastation

{% endfor %}

  loki:
    image: {{ loki_image }}
    restart: unless-stopped
    command: ["-config.file=/etc/loki/loki-config.yaml"]
    ports:
      - "{{ loki_port }}:3100"
    volumes:
      - {{ devastation_paths.observability }}/loki/loki-config.yaml:/etc/loki/loki-config.yaml:ro
      - {{ devastation_paths.observability }}/loki/data:/loki
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.loki }}

  jaeger:
    image: {{ jaeger_image }}
    restart: unless-stopped
    ports:
      - "{{ jaeger_ui_port }}:16686"
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.jaeger }}

  otel-collector:
    image: {{ otel_collector_image }}
    restart: unless-stopped
    command: ["--config=/etc/otelcol-contrib/config.yaml"]
    depends_on:
      - jaeger
      - loki
    ports:
      - "{{ otel_grpc_port }}:4317"
      - "{{ otel_http_port }}:4318"
    volumes:
      - {{ devastation_paths.observability }}/otel-collector/config.yaml:/etc/otelcol-contrib/config.yaml:ro
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.otel_collector }}

  prometheus:
    image: {{ prometheus_image }}
    restart: unless-stopped
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time={{ prometheus_retention }}
      - --web.enable-lifecycle
    ports:
      - "{{ prometheus_port }}:9090"
    volumes:
      - {{ devastation_paths.observability }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ devastation_paths.observability }}/prometheus/data:/prometheus
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.prometheus }}

  grafana:
    image: {{ grafana_image }}
    restart: unless-stopped
    environment:
      GF_SECURITY_ADMIN_USER: {{ grafana_admin_user }}
      GF_SECURITY_ADMIN_PASSWORD: {{ grafana_admin_password }}
      GF_USERS_ALLOW_SIGN_UP: "false"
      GF_METRICS_ENABLED: "true"
      GF_SERVER_ROOT_URL: http://grafana.{{ devastation_domain }}:{{ grafana_port }}
    depends_on:
      - prometheus
      - loki
      - jaeger
      - otel-db
    ports:
      - "{{ grafana_port }}:3000"
    volumes:
      - {{ devastation_paths.observability }}/grafana/data:/var/lib/grafana
      - {{ devastation_paths.observability }}/grafana/provisioning:/etc/grafana/provisioning:ro
      - {{ devastation_paths.observability }}/grafana/dashboards:/var/lib/grafana/dashboards:ro
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.grafana }}

  node-exporter:
    image: {{ node_exporter_image }}
    restart: unless-stopped
    command:
      - --path.procfs=/host/proc
      - --path.sysfs=/host/sys
      - --path.rootfs=/rootfs
      - --collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)
      - --collector.systemd
      - --collector.processes
    pid: host
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.node_exporter }}

  cadvisor:
    image: {{ cadvisor_image }}
    restart: unless-stopped
    privileged: true
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker:/var/lib/docker:ro
      - /dev/disk:/dev/disk:ro
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.cadvisor }}

  gitlab:
    image: gitlab/gitlab-ce:{{ gitlab_version }}
    restart: unless-stopped
    hostname: gitlab.{{ devastation_domain }}
    shm_size: "256m"
    environment:
      GITLAB_OMNIBUS_CONFIG: |
        external_url '{{ gitlab_external_url }}'
        gitlab_rails['gitlab_shell_ssh_port'] = {{ gitlab_ssh_port }}
        nginx['listen_port'] = 443
        nginx['listen_https'] = true
        nginx['ssl_certificate'] = "/devastation-certs/gitlab/tls.crt"
        nginx['ssl_certificate_key'] = "/devastation-certs/gitlab/tls.key"
        registry_external_url nil
    ports:
      - "{{ gitlab_http_port }}:80"
      - "{{ gitlab_https_port }}:443"
      - "{{ gitlab_ssh_port }}:22"
    volumes:
      - {{ devastation_paths.gitlab }}/config:/etc/gitlab
      - {{ devastation_paths.gitlab }}/logs:/var/log/gitlab
      - {{ devastation_paths.gitlab }}/data:/var/opt/gitlab
      - {{ devastation_paths.certs }}/gitlab.{{ devastation_domain }}:/devastation-certs/gitlab:ro
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.gitlab }}

  gitlab-runner:
    image: gitlab/gitlab-runner:{{ gitlab_runner_version }}
    restart: unless-stopped
    volumes:
      - {{ devastation_paths.gitlab_runner }}/config:/etc/gitlab-runner
      - {{ devastation_paths.ca }}/root-ca.crt:/etc/gitlab-runner/certs/ca.crt:ro
{% if gitlab_runner_mount_docker_socket %}
      - /var/run/docker.sock:/var/run/docker.sock
{% endif %}
    networks:
      devastation:
        ipv4_address: {{ devastation_subnets.runner }}

networks:
  devastation:
    name: devastation
    driver: bridge
    ipam:
      config:
        - subnet: {{ devastation_subnets.services }}
          gateway: {{ devastation_subnets.service_gateway }}
