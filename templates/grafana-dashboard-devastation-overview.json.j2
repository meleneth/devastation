{
  "uid": "devastation-overview",
  "title": "Devastation Overview",
  "tags": ["devastation", "local-dev", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Targets Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(up)" }
      ]
    },
    {
      "type": "stat",
      "title": "Targets Down",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(up == 0)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Host CPU Busy",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container Memory",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name) (container_memory_usage_bytes{name!=\"\"})",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Registry HTTP Requests",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job, code) (rate(registry_http_requests_total[5m]))",
          "legendFormat": "{{ job }} {{ code }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "OTel Collector Accepted Spans",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(otelcol_receiver_accepted_spans[5m]))",
          "legendFormat": "spans/s"
        }
      ]
    }
  ]
}
