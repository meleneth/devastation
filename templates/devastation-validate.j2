#!/usr/bin/env bash
set -euo pipefail

DOMAIN="{{ devastation_domain }}"
REGISTRY="registry.${DOMAIN}"
QUICK=0
CHECK_TMP="$(mktemp -d)"
CHECK_OUT="${CHECK_TMP}/check.out"
VALIDATION_TMP=""

cleanup() {
  rm -rf "$CHECK_TMP"
  if [[ -n "$VALIDATION_TMP" ]]; then
    rm -rf "$VALIDATION_TMP"
  fi
}

trap cleanup EXIT

if [[ "${1:-}" == "--quick" ]]; then
  QUICK=1
fi

check() {
  local name="$1"
  shift
  if "$@" >"$CHECK_OUT" 2>&1; then
    printf '[ok] %s\n' "$name"
  else
    printf '[fail] %s\n' "$name"
    sed 's/^/  /' "$CHECK_OUT"
    return 1
  fi
}

retry_check() {
  local name="$1"
  local attempts="$2"
  local delay="$3"
  local try
  shift 3

  for try in $(seq 1 "$attempts"); do
    if "$@" >"$CHECK_OUT" 2>&1; then
      printf '[ok] %s\n' "$name"
      return 0
    fi
    if [[ "$try" != "$attempts" ]]; then
      sleep "$delay"
    fi
  done

  printf '[fail] %s\n' "$name"
  sed 's/^/  /' "$CHECK_OUT"
  return 1
}

run_root() {
  if [[ "${EUID}" == "0" ]]; then
    "$@"
  elif command -v sudo >/dev/null 2>&1; then
    sudo -n "$@"
  else
    printf 'root privileges required for: %s\n' "$*" >&2
    return 1
  fi
}

status=0
for fqdn in{% for record in devastation_dns_records %} {{ record.name }}{% endfor %}; do
  check "dns ${fqdn}" getent hosts "${fqdn}" || status=1
done

check "host CA trust" test -f /usr/local/share/ca-certificates/devastation-root-ca.crt || status=1
check "ephemeral CA private key absent" run_root test ! -e "{{ devastation_paths.ca }}/root-ca.key" || status=1
check "certificate universe verifies" run_root "{{ ca_rotation_script }}" --verify-only || status=1
check "Docker running" docker info || status=1
check "registry reachable" curl -fsS "https://${REGISTRY}/v2/" || status=1
check "registry metrics reachable" curl -fsS "http://${REGISTRY}:{{ registry_metrics_port }}/metrics" || status=1
check "apt cache reachable" curl -fsS "http://apt-cache.${DOMAIN}:{{ apt_cache_port }}/acng-report.html" || status=1
check "Vault reachable" curl -fsS "http://vault.${DOMAIN}:{{ vault_port }}/v1/sys/health" || status=1
check "eventline GoAWS reachable" nc -z "eventline.${DOMAIN}" {{ goaws_port }} || status=1
check "storage MinIO reachable" curl -fsS "http://storage.${DOMAIN}:{{ minio_api_port }}/minio/health/live" || status=1
check "apex portal reachable" curl -fsS "https://${DOMAIN}/" || status=1
check "www portal reachable" curl -fsS "https://www.${DOMAIN}/" || status=1
check "www portal redirects HTTP to HTTPS" bash -c "curl -fsSI 'http://www.${DOMAIN}:{{ www_http_port }}/' | grep -qi '^location: https://www\\.${DOMAIN}/'" || status=1
check "Prometheus reachable" curl -fsS "http://prometheus.${DOMAIN}:{{ prometheus_port }}/-/ready" || status=1
check "Grafana reachable" curl -fsS "http://grafana.${DOMAIN}:{{ grafana_port }}/api/health" || status=1
check "Jaeger reachable" curl -fsS "http://jaeger.${DOMAIN}:{{ jaeger_ui_port }}/" || status=1
retry_check "Loki reachable" 24 5 curl -fsS "http://loki.${DOMAIN}:{{ loki_port }}/ready" || status=1
check "OTel Collector metrics reachable" curl -fsS "http://otel-collector.${DOMAIN}:8888/metrics" || status=1
check "OTel Collector Fluent Forward reachable" nc -z "otel-collector.${DOMAIN}" {{ otel_fluentforward_port }} || status=1
{% for pg in postgres_databases %}
check "{{ pg.service }} reachable" nc -z "{{ pg.hostname }}" 5432 || status=1
{% endfor %}
check "KIND cluster listed" kind get clusters || status=1
check "KIND API reachable at kind.${DOMAIN}" nc -z "kind.${DOMAIN}" {{ kind_api_port }} || status=1
check "kubectl cluster-info" kubectl cluster-info || status=1
check "Helm installed" helm version --short || status=1
check "k9s installed" k9s version || status=1
check "lazydocker installed" lazydocker --version || status=1
check "trivy installed" trivy --version || status=1
{% if kind_install_platform_addons %}
check "Istio installed" kubectl -n istio-system get deployment istiod || status=1
check "Argo CD installed" kubectl -n argocd get deployment argocd-server || status=1
check "OTel operator installed" kubectl -n opentelemetry-operator-system get deployment opentelemetry-operator-controller-manager || status=1
{% endif %}
retry_check "GitLab web reachable" 24 5 curl -kfsS "{{ gitlab_external_url }}/users/sign_in" || status=1
check "runner container running" docker compose -f "{{ devastation_paths.compose }}/compose.yml" ps --status running gitlab-runner || status=1
check "neovim installed" nvim --version || status=1

if [[ "$QUICK" == "0" ]]; then
  tmp="$(mktemp -d)"
  VALIDATION_TMP="$tmp"
  cat >"${tmp}/Dockerfile" <<'DOCKERFILE'
FROM alpine:3.20
CMD ["sh", "-c", "echo devastation-local && sleep 3600"]
DOCKERFILE
  image="${REGISTRY}/devastation/hello:local"
  check "build local registry test image" docker build -t "$image" "$tmp" || status=1
  check "push local registry test image" docker push "$image" || status=1
  check "pull local registry test image" docker pull "$image" || status=1
  kubectl delete namespace devastation-validate --ignore-not-found >/dev/null 2>&1 || true
  check "create validation namespace" kubectl create namespace devastation-validate || status=1
  check "run registry image in KIND" kubectl -n devastation-validate run hello --image="$image" --restart=Never || status=1
  check "wait for validation pod" kubectl -n devastation-validate wait --for=condition=Ready pod/hello --timeout=180s || status=1
  check "KIND resolves internal services" kubectl -n devastation-validate run dnscheck --image=busybox:1.36 --restart=Never --rm -i -- nslookup gitlab.${DOMAIN} || status=1
fi

exit "$status"
