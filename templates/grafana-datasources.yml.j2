apiVersion: 1

datasources:
  - name: Prometheus
    uid: prometheus
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    isDefault: true

  - name: Loki
    uid: loki
    type: loki
    access: proxy
    url: http://loki:3100

  - name: Jaeger
    uid: jaeger
    type: jaeger
    access: proxy
    url: http://jaeger:16686

{% for pg in postgres_databases %}
  - name: {{ pg.service }}
    uid: {{ pg.service | replace('-', '_') }}
    type: postgres
    access: proxy
    url: {{ pg.service }}:5432
    user: {{ postgres_default_user }}
    database: {{ pg.database }}
    secureJsonData:
      password: {{ postgres_default_password }}
    jsonData:
      sslmode: disable
      postgresVersion: 1800
      timescaledb: false

{% endfor %}
