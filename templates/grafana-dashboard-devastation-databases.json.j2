{
  "uid": "devastation-databases",
  "title": "Devastation Databases",
  "tags": ["devastation", "postgres"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Postgres Exporters Up",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(up{job=~\"postgres-.*\"})" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Database Size",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_database_size_bytes",
          "legendFormat": "{{ '{{' }} datname {{ '}}' }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Active Connections",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (pg_stat_activity_count)",
          "legendFormat": "{{ '{{' }} datname {{ '}}' }}"
        }
      ]
    }
  ]
}
