{
  "uid": "devastation-www",
  "title": "Devastation WWW",
  "tags": ["devastation", "www", "nginx", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "WWW Container Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(time() - container_last_seen{container_label_com_docker_compose_service=\"www\"} < 60)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Down" }, "1": { "text": "Up" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "WWW Logs / Sec",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({service_name=\"www\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WWW CPU",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"www\"}[5m]))",
          "legendFormat": "www"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WWW Memory",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "container_memory_working_set_bytes{container_label_com_docker_compose_service=\"www\"}",
          "legendFormat": "working set"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "WWW Network",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=\"www\"}[5m]))",
          "legendFormat": "receive"
        },
        {
          "refId": "B",
          "expr": "sum(rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=\"www\"}[5m]))",
          "legendFormat": "transmit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "WWW Log Volume",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"www\"}[5m]))",
          "legendFormat": "log lines"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "OTel WWW Log Intake",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(otelcol_receiver_accepted_log_records{receiver=\"fluent_forward/www\"}[5m]))",
          "legendFormat": "accepted"
        },
        {
          "refId": "B",
          "expr": "sum(rate(otelcol_receiver_refused_log_records{receiver=\"fluent_forward/www\"}[5m]))",
          "legendFormat": "refused"
        }
      ]
    },
    {
      "type": "logs",
      "title": "WWW Logs",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"www\"}"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "type": "logs",
      "title": "WWW Errors",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"www\"} |~ \"(?i)( 5[0-9][0-9] |error|crit|alert|emerg)\""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
