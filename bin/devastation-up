#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")/.."

if ! ansible-galaxy collection list community.docker >/dev/null 2>&1; then
  ansible-galaxy collection install -r requirements.yml
fi

args=("$@")
needs_become_prompt=1

for arg in "${args[@]}"; do
  case "$arg" in
    -K|--ask-become-pass)
      needs_become_prompt=0
      ;;
    --become-password-file|--become-password-file=*)
      needs_become_prompt=0
      ;;
  esac
done

if [[ "${DEVASTATION_ASSUME_WARM_SUDO:-0}" == "1" ]]; then
  needs_become_prompt=0
fi

if [[ "$needs_become_prompt" == "1" ]]; then
  if [[ ! -t 0 ]]; then
    printf 'sudo needs a password, but devastation-up has no interactive stdin for Ansible to prompt on.\n' >&2
    printf 'Run ./bin/devastation-up from a terminal, warm sudo first, or pass --become-password-file.\n' >&2
    exit 1
  fi
  args=(--ask-become-pass "${args[@]}")
fi

if [[ "${DEVASTATION_DEBUG_UP:-0}" == "1" ]]; then
  printf 'devastation-up: running ansible-playbook' >&2
  printf ' %q' playbooks/bootstrap.yml "${args[@]}" >&2
  printf '\n' >&2
fi

ansible-playbook playbooks/bootstrap.yml "${args[@]}"

home_url="${DEVASTATION_HOME_URL:-http://www.deva.station}"
open_home="${DEVASTATION_OPEN_HOME:-1}"

if [[ "$open_home" == "1" ]]; then
  if command -v xdg-open >/dev/null 2>&1; then
    nohup xdg-open "$home_url" >/dev/null 2>&1 &
    printf 'Opened %s\n' "$home_url"
  elif command -v sensible-browser >/dev/null 2>&1; then
    nohup sensible-browser "$home_url" >/dev/null 2>&1 &
    printf 'Opened %s\n' "$home_url"
  elif command -v gio >/dev/null 2>&1; then
    nohup gio open "$home_url" >/dev/null 2>&1 &
    printf 'Opened %s\n' "$home_url"
  else
    printf 'Devastation home: %s\n' "$home_url"
  fi
else
  printf 'Devastation home: %s\n' "$home_url"
fi
