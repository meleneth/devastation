#!/usr/bin/env bash
set -euo pipefail

COMPOSE_FILE="${DEVASTATION_COMPOSE_FILE:-/srv/devastation/compose/compose.yml}"

if [[ ! -f "$COMPOSE_FILE" ]]; then
  echo "Compose file not found: $COMPOSE_FILE"
  exit 1
fi

docker compose -f "$COMPOSE_FILE" down
echo "Services stopped. Persistent data under /srv/devastation was not deleted."
