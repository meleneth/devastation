#!/usr/bin/env bash
set -euo pipefail

cat >&2 <<'EOF'
Single-certificate minting is disabled.

devastation uses an ephemeral root CA private key. The key exists only during
full trust-universe rotation and is destroyed immediately after signing.

Add the hostname to group_vars/all.yml, then run:

  ./bin/devastation-rotate-trust-universe

EOF
exit 2
